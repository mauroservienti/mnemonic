{
  "name": "mnemonic",
  "version": "0.1.0",
  "description": "A local MCP memory server backed by markdown + JSON files, synced via git",
  "type": "module",
  "bin": {
    "mnemonic": "./build/index.js"
  },
  "scripts": {
    "build": "tsc && chmod 755 build/index.js",
    "dev": "tsc --watch",
    "start": "node build/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.1",
    "gray-matter": "^4.0.3",
    "markdownlint": "^0.40.0",
    "simple-git": "^3.27.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  }
}
